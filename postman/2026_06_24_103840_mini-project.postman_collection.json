    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// ระบุชื่อ Request ที่ต้องการให้สคริปต์นี้ทำงาน (อิงตามชื่อที่ตั้งใน Postman)",
          "const targetRequests = [\"login\", \"register\"];",
          "",
          "// เช็กว่าถ้ารายชื่อ Request ตรงกัน ค่อยรันสคริปต์เก็บ Token",
          "if (targetRequests.includes(pm.info.requestName.toLowerCase())) {",
          "    if (pm.response.code >= 200 && pm.response.code < 300) {",
          "        try {",
          "            var jsonData = pm.response.json();",
          "            if (jsonData && jsonData.access_token) {",
          "                pm.environment.set(\"TOKEN\", jsonData.access_token);",
          "            }",
          "        } catch (e) {",
          "            console.error(\"Response is not a valid JSON\");",
          "        }",
          "    }",
          "}"
        ]
      }
    }
